<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.recetea.infrastructure.ui.CreateRecipeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Nueva Receta">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <GridPane vgap="10.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Título:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="titleField" promptText="Ej. Paella Valenciana" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Tiempo (min):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="prepTimeField" promptText="45" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Raciones:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="servingsField" promptText="4" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="Descripción:" />
    <TextArea fx:id="descriptionArea" prefRowCount="4" promptText="Describe brevemente la receta..." />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Cancelar / Volver" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" onAction="#onBackButtonClick" />

        <Button text="Guardar Receta" style="-fx-background-color: #2196F3; -fx-text-fill: white;" onAction="#onSaveButtonClick" />
    </HBox>
</VBox>