<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.recetea.infrastructure.ui.CreateRecipeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Constructor de Receta">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <TitledPane text="1. Datos Generales" collapsible="false">
        <GridPane vgap="10.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Título:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="titleField" promptText="Ej. Paella Valenciana" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Tiempo (min):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="prepTimeField" promptText="45" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Raciones:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="servingsField" promptText="4" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Descripción:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Paso a paso de la receta..." GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>
    </TitledPane>

    <TitledPane text="2. Lista de Ingredientes" collapsible="false" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="ingredientIdField" promptText="ID Ingrediente" prefWidth="120.0"/>
                <TextField fx:id="unitIdField" promptText="ID Unidad" prefWidth="120.0"/>
                <TextField fx:id="quantityField" promptText="Cantidad" prefWidth="120.0"/>
                <Button text="+ Añadir Ingrediente" style="-fx-background-color: #FF9800; -fx-text-fill: white;" onAction="#onAddIngredientClick"/>
            </HBox>

            <TableView fx:id="ingredientsTable" prefHeight="150.0" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colIngredientId" prefWidth="100.0" text="ID Ingrediente" />
                    <TableColumn fx:id="colUnitId" prefWidth="100.0" text="ID Unidad" />
                    <TableColumn fx:id="colQuantity" prefWidth="100.0" text="Cantidad" />
                </columns>
            </TableView>
        </VBox>
    </TitledPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Cancelar / Volver" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" onAction="#onBackButtonClick" />
        <Button text="Sellar y Guardar Receta Completa" style="-fx-background-color: #2196F3; -fx-text-fill: white;" onAction="#onSaveButtonClick" />
    </HBox>
</VBox>