<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.recetea.infrastructure.ui.controllers.RecipeDetailController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="titleLabel" text="Cargando Receta...">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <GridPane vgap="10.0" hgap="15.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Tiempo de Prep:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="prepTimeLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Raciones:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="servingsLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Descripción:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="descriptionLabel" text="-" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator />

    <Label text="Ingredientes Necesarios">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <TableView fx:id="ingredientsTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colIngredientId" prefWidth="150.0" text="Ingrediente" />
            <TableColumn fx:id="colUnitId" prefWidth="100.0" text="Unidad" />
            <TableColumn fx:id="colQuantity" prefWidth="100.0" text="Cantidad" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Volver al Catálogo"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"
                onAction="#onBackButtonClick" />
    </HBox>
</VBox>