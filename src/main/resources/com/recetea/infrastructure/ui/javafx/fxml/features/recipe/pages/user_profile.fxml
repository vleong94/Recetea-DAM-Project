<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" maxWidth="Infinity" maxHeight="Infinity"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.recetea.infrastructure.ui.javafx.features.recipe.controllers.UserProfileController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
    </padding>

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="%profile.title" styleClass="header-label" HBox.hgrow="ALWAYS" />
        <Button text="%nav.back.toCatalog" styleClass="secondary-button" onAction="#onBackButtonClick" />
    </HBox>

    <!-- ── Tab Pane ─────────────────────────────────────────────────────── -->
    <TabPane VBox.vgrow="ALWAYS">

        <!-- Tab 1: Mis Creaciones -->
        <Tab text="%profile.tab.myRecipes" closable="false">
            <content>
                <VBox spacing="12.0">
                    <padding>
                        <Insets top="12.0" />
                    </padding>

                    <!-- Empty state -->
                    <VBox fx:id="creationsEmpty" alignment="CENTER" spacing="8.0"
                          visible="false" managed="false" VBox.vgrow="ALWAYS"
                          styleClass="glass-card">
                        <Label text="✎" styleClass="empty-state-icon" />
                        <Label text="%profile.creations.empty.title" styleClass="section-header" />
                        <Label text="%profile.creations.empty.message" styleClass="text-caption" />
                    </VBox>

                    <!-- Card gallery -->
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                        <FlowPane fx:id="creationsContainer" hgap="20.0" vgap="20.0">
                            <padding>
                                <Insets bottom="8.0" left="4.0" right="4.0" top="8.0" />
                            </padding>
                        </FlowPane>
                    </ScrollPane>
                </VBox>
            </content>
        </Tab>

        <!-- Tab 2: Mis Favoritos -->
        <Tab text="%profile.tab.myFavorites" closable="false">
            <content>
                <VBox spacing="12.0">
                    <padding>
                        <Insets top="12.0" />
                    </padding>

                    <!-- Empty state -->
                    <VBox fx:id="favoritesEmpty" alignment="CENTER" spacing="8.0"
                          visible="false" managed="false" VBox.vgrow="ALWAYS"
                          styleClass="glass-card">
                        <Label text="☆" styleClass="empty-state-icon" />
                        <Label text="%profile.favorites.empty.title" styleClass="section-header" />
                        <Label text="%profile.favorites.empty.message" styleClass="text-caption" />
                    </VBox>

                    <!-- Card gallery -->
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                        <FlowPane fx:id="favoritesContainer" hgap="20.0" vgap="20.0">
                            <padding>
                                <Insets bottom="8.0" left="4.0" right="4.0" top="8.0" />
                            </padding>
                        </FlowPane>
                    </ScrollPane>
                </VBox>
            </content>
        </Tab>

    </TabPane>
</VBox>
