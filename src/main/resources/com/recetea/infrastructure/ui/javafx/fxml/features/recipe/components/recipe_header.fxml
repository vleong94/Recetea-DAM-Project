<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="VBox" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <Label text="%recipe.form.section.header" styleClass="section-header" />

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="%recipe.form.field.title" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label" />
        <TextField fx:id="titleField" promptText="%recipe.form.field.title.prompt" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="%recipe.form.field.prepTime" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label" />
        <TextField fx:id="prepTimeField" promptText="%recipe.form.field.prepTime.prompt" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="%recipe.form.field.servings" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label" />
        <TextField fx:id="servingsField" promptText="%recipe.form.field.servings.prompt" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="%field.label.category" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label" />
        <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />

        <Label text="%field.label.difficulty" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="field-label" />
        <ComboBox fx:id="difficultyComboBox" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1" />

        <Label text="%recipe.form.field.description" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="field-label" />
        <TextArea fx:id="descriptionArea" prefHeight="100.0" wrapText="true" GridPane.rowIndex="5" GridPane.columnIndex="1" />
    </GridPane>
</fx:root>
