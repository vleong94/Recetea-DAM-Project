<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0" maxWidth="360.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.recetea.infrastructure.ui.javafx.features.identity.controllers.RegisterController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Crear cuenta" styleClass="header-label" />

    <TextField fx:id="usernameField" promptText="Nombre de usuario" maxWidth="Infinity" />

    <TextField fx:id="emailField" promptText="Correo electrónico" maxWidth="Infinity" />

    <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="Infinity" />

    <PasswordField fx:id="confirmPasswordField" promptText="Confirmar contraseña" maxWidth="Infinity" />

    <Label fx:id="errorLabel" text="" styleClass="error-label" maxWidth="Infinity" wrapText="true" />

    <Button text="Registrarse" styleClass="primary-button" maxWidth="Infinity" onAction="#onRegisterButtonClick" />

    <Hyperlink text="¿Ya tienes cuenta? Inicia sesión" onAction="#onBackToLoginLinkClick" />

</VBox>
