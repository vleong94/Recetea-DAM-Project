<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.recetea.infrastructure.ui.javafx.features.recipe.controllers.RecipeDashboardController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Catálogo de Recetas" styleClass="header-label" HBox.hgrow="ALWAYS" />
        <Button text="Cerrar sesión" styleClass="secondary-button" onAction="#onLogoutButtonClick" />
    </HBox>

    <TableView fx:id="recipeTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="titleColumn" prefWidth="200.0" text="Título de la Receta" />
            <TableColumn fx:id="categoryColumn" prefWidth="120.0" text="Categoría" />
            <TableColumn fx:id="difficultyColumn" prefWidth="100.0" text="Dificultad" />
            <TableColumn fx:id="prepColumn" prefWidth="90.0" text="Prep (min)" />
            <TableColumn fx:id="servingsColumn" prefWidth="80.0" text="Raciones" />
            <TableColumn fx:id="scoreColumn" prefWidth="80.0" text="Score" />
            <TableColumn fx:id="ratingsColumn" prefWidth="60.0" text="Votes" />
            <TableColumn fx:id="actionsColumn" prefWidth="140.0" text="Acciones" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Nueva Receta" styleClass="primary-button" onAction="#onCreateButtonClick" />
    </HBox>

</VBox>