<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.recetea</groupId>
    <artifactId>Recetea</artifactId>
    <version>1.0-SNAPSHOT</version>

    <properties>
        <!-- Single source-of-truth for the Java release; consumed by the compiler plugin. -->
        <java.version>24</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Runtime dependency versions -->
        <postgresql.version>42.7.10</postgresql.version>
        <javafx.version>26.0.1</javafx.version>
        <hikaricp.version>7.0.2</hikaricp.version>
        <jbcrypt.version>0.4</jbcrypt.version>
        <jaxb.api.version>4.0.2</jaxb.api.version>
        <jaxb.runtime.version>4.0.5</jaxb.runtime.version>
        <jakarta.activation.version>2.1.3</jakarta.activation.version>
        <openpdf.version>3.0.3</openpdf.version>
        <slf4j.version>2.0.17</slf4j.version>
        <logback.version>1.5.32</logback.version>
        <json.version>20251224</json.version>

        <!-- Test dependency versions -->
        <junit.version>6.0.3</junit.version>
        <mockito.version>5.23.0</mockito.version>
        <archunit.version>1.4.2</archunit.version>
        <pitest.version>1.19.1</pitest.version>
        <pitest.junit5.version>1.2.3</pitest.junit5.version>

        <!-- Plugin versions -->
        <maven.compiler.plugin.version>3.13.0</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.5.5</maven.surefire.plugin.version>
    </properties>

    <!--
      BOM (Bill of Materials) – centralises version governance for artifact families
      that ship multiple co-versioned JARs. Prevents transitive pulls from silently
      downgrading or mixing incompatible minor versions.
    -->
    <dependencyManagement>
        <dependencies>

            <!-- JUnit BOM: pins every org.junit.jupiter.* / org.junit.platform.* artifact
                 to the same version so split-version classpath issues are impossible. -->
            <dependency>
                <groupId>org.junit</groupId>
                <artifactId>junit-bom</artifactId>
                <version>${junit.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- JavaFX: lock all platform JARs (including transitively pulled
                 javafx-base and javafx-graphics) to one consistent version. -->
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-base</artifactId>
                <version>${javafx.version}</version>
            </dependency>
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-graphics</artifactId>
                <version>${javafx.version}</version>
            </dependency>
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-controls</artifactId>
                <version>${javafx.version}</version>
            </dependency>
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-fxml</artifactId>
                <version>${javafx.version}</version>
            </dependency>

            <!-- Jakarta XML Binding: api and runtime must be upgraded together.
                 Pinning both here prevents jaxb-runtime from pulling a different
                 api version as a transitive dependency. -->
            <dependency>
                <groupId>jakarta.xml.bind</groupId>
                <artifactId>jakarta.xml.bind-api</artifactId>
                <version>${jaxb.api.version}</version>
            </dependency>
            <dependency>
                <groupId>org.glassfish.jaxb</groupId>
                <artifactId>jaxb-runtime</artifactId>
                <version>${jaxb.runtime.version}</version>
            </dependency>
            <!-- Activation API is pulled by both jaxb-api and jaxb-core;
                 a single managed version prevents duplicate class-path entries. -->
            <dependency>
                <groupId>jakarta.activation</groupId>
                <artifactId>jakarta.activation-api</artifactId>
                <version>${jakarta.activation.version}</version>
            </dependency>

            <!-- SLF4J: API version pinned here; HikariCP also pulls it transitively. -->
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>slf4j-api</artifactId>
                <version>${slf4j.version}</version>
            </dependency>

            <!-- Logback: both JARs must stay co-versioned. -->
            <dependency>
                <groupId>ch.qos.logback</groupId>
                <artifactId>logback-classic</artifactId>
                <version>${logback.version}</version>
            </dependency>
            <dependency>
                <groupId>ch.qos.logback</groupId>
                <artifactId>logback-core</artifactId>
                <version>${logback.version}</version>
            </dependency>

        </dependencies>
    </dependencyManagement>

    <dependencies>

        <!-- Persistence -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>${postgresql.version}</version>
        </dependency>
        <dependency>
            <groupId>com.zaxxer</groupId>
            <artifactId>HikariCP</artifactId>
            <version>${hikaricp.version}</version>
        </dependency>

        <!-- UI Framework – versions resolved from dependencyManagement above -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
        </dependency>

        <!-- Security -->
        <dependency>
            <groupId>org.mindrot</groupId>
            <artifactId>jbcrypt</artifactId>
            <version>${jbcrypt.version}</version>
        </dependency>

        <!-- XML Interoperability – versions resolved from dependencyManagement above -->
        <dependency>
            <groupId>jakarta.xml.bind</groupId>
            <artifactId>jakarta.xml.bind-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.glassfish.jaxb</groupId>
            <artifactId>jaxb-runtime</artifactId>
        </dependency>

        <!-- PDF Reports -->
        <dependency>
            <groupId>com.github.librepdf</groupId>
            <artifactId>openpdf</artifactId>
            <version>${openpdf.version}</version>
        </dependency>

        <!-- JSON parsing for JSONB aggregate hydration -->
        <dependency>
            <groupId>org.json</groupId>
            <artifactId>json</artifactId>
            <version>${json.version}</version>
        </dependency>

        <!-- Logging: SLF4J API + Logback binding (compile = available everywhere incl. tests) -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-core</artifactId>
        </dependency>

        <!-- Test dependencies – JUnit version resolved from junit-bom import above -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.tngtech.archunit</groupId>
            <artifactId>archunit-junit5</artifactId>
            <version>${archunit.version}</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler.plugin.version}</version>
                <configuration>
                    <!--
                      <release> supersedes the legacy <source>/<target> pair: it also enforces
                      the JDK API boundary, preventing accidental use of APIs from a newer JDK.
                      Preview flag must be declared here (compile) AND in Surefire (runtime).
                    -->
                    <release>${java.version}</release>
                    <parameters>true</parameters>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${maven.surefire.plugin.version}</version>
                <configuration>
                    <!-- Classes compiled with preview features require the same flag at runtime. -->
                    <argLine>--enable-preview</argLine>
                </configuration>
            </plugin>

            <!--
              JavaFX Maven Plugin – three goals, none bound to the default lifecycle:
                mvn javafx:run      → launch the app from source (dev workflow)
                mvn javafx:jlink    → build an optimised JRE image under target/recetea-runtime/
                mvn javafx:jpackage → wrap the jlink image in a platform installer (target/installer/)

              Prerequisites for jpackage:
                Windows: WiX Toolset 3.x on PATH  (produces .msi)
                Linux  : rpm-build or dpkg-deb     (produces .rpm/.deb)
                macOS  : Xcode CLI tools            (produces .dmg/.pkg)
            -->
            <plugin>
                <groupId>org.pitest</groupId>
                <artifactId>pitest-maven</artifactId>
                <version>${pitest.version}</version>
                <dependencies>
                    <dependency>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-junit5-plugin</artifactId>
                        <version>${pitest.junit5.version}</version>
                    </dependency>
                </dependencies>
                <configuration>
                    <!--
                      Default scope: core domain + application unit tests only.
                      Integration tests (DB/filesystem) are in infrastructure packages
                      and are excluded to keep mutation runs fast and deterministic.
                    -->
                    <targetClasses>
                        <param>com.recetea.core.*</param>
                    </targetClasses>
                    <targetTests>
                        <param>com.recetea.core.*</param>
                    </targetTests>
                    <outputFormats>
                        <outputFormat>HTML</outputFormat>
                        <outputFormat>XML</outputFormat>
                    </outputFormats>
                    <!-- Preview flag must match the compile configuration. -->
                    <jvmArgs>
                        <jvmArg>--enable-preview</jvmArg>
                    </jvmArgs>
                    <!--
                      frecord is disabled because PITest 1.19.1 incorrectly classifies
                      the entire canonical record constructor as compiler-generated,
                      silently dropping all mutations from compact constructors that
                      contain developer-written validation logic.
                    -->
                    <features>
                        <feature>-frecord</feature>
                    </features>
                    <!-- Overwrite report on each run instead of creating dated folders. -->
                    <timestampedReports>false</timestampedReports>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <!-- Modular main class: module/class -->
                    <mainClass>com.recetea/com.recetea.Main</mainClass>

                    <!-- JVM flags forwarded to the launcher (run + jlink-generated script) -->
                    <options>
                        <option>--enable-preview</option>
                    </options>

                    <!-- jlink: stripped JRE image for Corretto 24 -->
                    <jlinkImageName>recetea-runtime</jlinkImageName>
                    <launcher>recetea</launcher>
                    <compress>2</compress>
                    <noHeaderFiles>true</noHeaderFiles>
                    <noManPages>true</noManPages>
                    <stripDebug>true</stripDebug>

                    <!-- jpackage: platform-specific installer -->
                    <jpackageName>Recetea</jpackageName>
                    <jpackageAppVersion>1.0.0</jpackageAppVersion>
                    <jpackageType>msi</jpackageType>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>
